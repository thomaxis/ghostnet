{
  "name": "@ghostnet/apiv1-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@ghostnet/apiv1"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "apps/apiv1-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "@ghostnet/apiv1:build",
          "@ghostnet/apiv1:serve"
        ]
      }
    }
  }
}
